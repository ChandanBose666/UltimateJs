{
  "name": "@blazefw/inspector",
  "version": "0.1.1",
  "type": "module",
  "description": "Blazefw Inspector — browser overlay showing server/client component split in real-time",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
