{
  "name": "@blazefw/sidecar",
  "version": "0.1.0",
  "type": "module",
  "description": "Blazefw sidecar worker — offloads 3rd-party scripts to a Web Worker with DOM proxy",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=src"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": { "access": "public" }
}
