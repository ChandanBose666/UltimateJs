{
  "name": "@blazefw/compiler",
  "version": "0.1.1",
  "description": "BlazeFW Rust/WASM compiler — server/client slicer and accessibility scanner",
  "type": "module",
  "scripts": {
    "build": "cargo build --release || node build-stub.mjs",
    "build:wasm": "wasm-pack build --target nodejs --out-dir pkg-node",
    "dev": "cargo watch -x 'build --release'"
  },
  "exports": {
    ".": {
      "default": "./pkg-node/compiler.js"
    },
    "./wasm": "./wasm.js"
  },
  "files": [
    "pkg-node",
    "wasm.js",
    "build-stub.mjs"
  ]
}
